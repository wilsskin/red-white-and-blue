{% doc %}
  @prompt
    Add infinite scroll to the collection product grid so that products load automatically as the user scrolls down, replacing the existing "Load more" button functionality.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-infinite-scroll-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-infinite-scroll__loading-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.loading_text_color }};
  }

  .ai-infinite-scroll__loading-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-infinite-scroll__spinner-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.spinner_size }}px;
    height: {{ block.settings.spinner_size }}px;
    border: {{ block.settings.spinner_thickness }}px solid {{ block.settings.spinner_track_color }};
    border-top-color: {{ block.settings.spinner_color }};
    border-radius: 50%;
    animation: ai-infinite-scroll-spin-{{ ai_gen_id }} 0.8s linear infinite;
  }

  @keyframes ai-infinite-scroll-spin-{{ ai_gen_id }} {
    to {
      transform: rotate(360deg);
    }
  }

  .ai-infinite-scroll__loading-text-{{ ai_gen_id }} {
    margin-top: 16px;
    font-size: {{ block.settings.loading_text_size }}px;
  }

  .ai-infinite-scroll__end-message-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.end_message_color }};
    font-size: {{ block.settings.end_message_size }}px;
  }

  .ai-infinite-scroll__end-message-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-infinite-scroll__error-{{ ai_gen_id }} {
    display: none;
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.error_color }};
    font-size: 14px;
  }

  .ai-infinite-scroll__error-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-infinite-scroll__trigger-{{ ai_gen_id }} {
    height: 1px;
    width: 100%;
    visibility: hidden;
  }
{% endstyle %}

<infinite-scroll-{{ ai_gen_id }}
  class="ai-infinite-scroll-{{ ai_gen_id }}"
  data-threshold="{{ block.settings.scroll_threshold }}"
  data-collection-url="{{ collection.url }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-infinite-scroll__trigger-{{ ai_gen_id }}"></div>

  <div class="ai-infinite-scroll__loading-{{ ai_gen_id }}">
    <div class="ai-infinite-scroll__spinner-{{ ai_gen_id }}"></div>
    {% if block.settings.loading_text != blank %}
      <div class="ai-infinite-scroll__loading-text-{{ ai_gen_id }}">
        {{ block.settings.loading_text }}
      </div>
    {% endif %}
  </div>

  <div class="ai-infinite-scroll__end-message-{{ ai_gen_id }}">
    {{ block.settings.end_message }}
  </div>

  <div class="ai-infinite-scroll__error-{{ ai_gen_id }}">
    {{ block.settings.error_message }}
  </div>
</infinite-scroll-{{ ai_gen_id }}>

<script>
  (function() {
    class InfiniteScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentPage = 1;
        this.isLoading = false;
        this.hasMorePages = true;
        this.observer = null;
        this.productGrid = null;
        this.paginationContainer = null;
      }

      connectedCallback() {
        this.trigger = this.querySelector('.ai-infinite-scroll__trigger-{{ ai_gen_id }}');
        this.loadingIndicator = this.querySelector('.ai-infinite-scroll__loading-{{ ai_gen_id }}');
        this.endMessage = this.querySelector('.ai-infinite-scroll__end-message-{{ ai_gen_id }}');
        this.errorMessage = this.querySelector('.ai-infinite-scroll__error-{{ ai_gen_id }}');
        this.threshold = parseInt(this.dataset.threshold) || 200;
        this.collectionUrl = this.dataset.collectionUrl;

        this.findProductGrid();
        this.hidePagination();
        this.setupIntersectionObserver();
      }

      findProductGrid() {
        this.productGrid = document.querySelector('.collection-product-grid, .product-grid, [data-product-grid]');
        
        if (!this.productGrid) {
          const possibleGrids = document.querySelectorAll('[class*="grid"], [class*="collection"]');
          for (const grid of possibleGrids) {
            if (grid.querySelector('[class*="product"]')) {
              this.productGrid = grid;
              break;
            }
          }
        }
      }

      hidePagination() {
        this.paginationContainer = document.querySelector('.pagination, [data-pagination], [class*="pagination"]');
        if (this.paginationContainer) {
          this.paginationContainer.style.display = 'none';
          
          const nextLink = this.paginationContainer.querySelector('a[href*="page="]');
          if (nextLink) {
            const url = new URL(nextLink.href);
            const pageParam = url.searchParams.get('page');
            if (pageParam) {
              this.currentPage = parseInt(pageParam) - 1;
            }
          } else {
            this.hasMorePages = false;
            this.showEndMessage();
          }
        }
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: `${this.threshold}px`,
          threshold: 0
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.isLoading && this.hasMorePages) {
              this.loadMoreProducts();
            }
          });
        }, options);

        this.observer.observe(this.trigger);
      }

      async loadMoreProducts() {
        if (this.isLoading || !this.hasMorePages) return;

        this.isLoading = true;
        this.showLoading();
        this.hideError();

        try {
          this.currentPage++;
          const url = `${this.collectionUrl}?page=${this.currentPage}`;
          const response = await fetch(url);

          if (!response.ok) {
            throw new Error('Failed to load products');
          }

          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');

          const newProducts = doc.querySelectorAll('.product-card, [data-product-card], [class*="product-item"]');
          
          if (newProducts.length === 0) {
            this.hasMorePages = false;
            this.hideLoading();
            this.showEndMessage();
            return;
          }

          if (this.productGrid) {
            newProducts.forEach((product) => {
              this.productGrid.appendChild(product.cloneNode(true));
            });
          }

          const nextPagination = doc.querySelector('.pagination, [data-pagination]');
          const hasNextPage = nextPagination && nextPagination.querySelector('a[href*="page=' + (this.currentPage + 1) + '"]');
          
          if (!hasNextPage) {
            this.hasMorePages = false;
            this.hideLoading();
            this.showEndMessage();
          } else {
            this.hideLoading();
          }

        } catch (error) {
          console.error('Error loading products:', error);
          this.showError();
          this.hideLoading();
          this.hasMorePages = false;
        } finally {
          this.isLoading = false;
        }
      }

      showLoading() {
        this.loadingIndicator.classList.add('active');
      }

      hideLoading() {
        this.loadingIndicator.classList.remove('active');
      }

      showEndMessage() {
        this.endMessage.classList.add('active');
      }

      showError() {
        this.errorMessage.classList.add('active');
      }

      hideError() {
        this.errorMessage.classList.remove('active');
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('infinite-scroll-{{ ai_gen_id }}', InfiniteScroll{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Infinite scroll",
  "settings": [
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "range",
      "id": "scroll_threshold",
      "label": "Load distance",
      "min": 100,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 200,
      "info": "Distance from bottom before loading more products"
    },
    {
      "type": "header",
      "content": "Loading indicator"
    },
    {
      "type": "range",
      "id": "spinner_size",
      "label": "Spinner size",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "spinner_thickness",
      "label": "Spinner thickness",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "color",
      "id": "spinner_color",
      "label": "Spinner color",
      "default": "#1d58ba"
    },
    {
      "type": "color",
      "id": "spinner_track_color",
      "label": "Spinner track color",
      "default": "#e0e0e0"
    },
    {
      "type": "inline_richtext",
      "id": "loading_text",
      "label": "Loading text",
      "default": "Loading more products..."
    },
    {
      "type": "range",
      "id": "loading_text_size",
      "label": "Loading text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "loading_text_color",
      "label": "Loading text color",
      "default": "#2c2d2e"
    },
    {
      "type": "header",
      "content": "End message"
    },
    {
      "type": "inline_richtext",
      "id": "end_message",
      "label": "End message",
      "default": "You've viewed all products"
    },
    {
      "type": "range",
      "id": "end_message_size",
      "label": "End message size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "end_message_color",
      "label": "End message color",
      "default": "#808080"
    },
    {
      "type": "header",
      "content": "Error message"
    },
    {
      "type": "inline_richtext",
      "id": "error_message",
      "label": "Error message",
      "default": "Unable to load more products. Please refresh the page."
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error color",
      "default": "#c62a32"
    }
  ],
  "presets": [
    {
      "name": "Infinite scroll"
    }
  ]
}
{% endschema %}
