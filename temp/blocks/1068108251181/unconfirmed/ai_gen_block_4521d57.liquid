{% doc %}
  @prompt
    Add infinite scroll to the collection product grid so that products load automatically as the user scrolls down, replacing the existing "Load more" button functionality.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-infinite-scroll-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-infinite-scroll__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 40px;
  }

  @media screen and (max-width: 749px) {
    .ai-infinite-scroll__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }

  .ai-infinite-scroll__product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-infinite-scroll__product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-infinite-scroll__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-infinite-scroll__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-infinite-scroll__product-info-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-infinite-scroll__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-infinite-scroll__product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-infinite-scroll__product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.accent_color }};
  }

  .ai-infinite-scroll__product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 500;
  }

  .ai-infinite-scroll__loading-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.loading_text_color }};
    font-size: 16px;
  }

  .ai-infinite-scroll__spinner-{{ ai_gen_id }} {
    display: inline-block;
    width: 40px;
    height: 40px;
    border: 4px solid {{ block.settings.spinner_color }};
    border-top-color: transparent;
    border-radius: 50%;
    animation: ai-infinite-scroll-spin-{{ ai_gen_id }} 0.8s linear infinite;
  }

  @keyframes ai-infinite-scroll-spin-{{ ai_gen_id }} {
    to {
      transform: rotate(360deg);
    }
  }

  .ai-infinite-scroll__end-message-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.end_message_color }};
    font-size: 16px;
  }

  .ai-infinite-scroll__error-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #d82c0d;
    font-size: 16px;
  }

  .ai-infinite-scroll__hidden-{{ ai_gen_id }} {
    display: none;
  }
{% endstyle %}

<infinite-scroll-{{ ai_gen_id }}
  class="ai-infinite-scroll-{{ ai_gen_id }}"
  data-collection-handle="{{ collection.handle }}"
  data-threshold="{{ block.settings.scroll_threshold }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-infinite-scroll__grid-{{ ai_gen_id }}" data-product-grid>
    {% if collection.products.size > 0 %}
      {% for product in collection.products %}
        <div class="ai-infinite-scroll__product-card-{{ ai_gen_id }}">
          <div class="ai-infinite-scroll__image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-infinite-scroll__image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              <div class="ai-infinite-scroll__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-infinite-scroll__product-info-{{ ai_gen_id }}">
            <h3 class="ai-infinite-scroll__product-title-{{ ai_gen_id }}">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            <div class="ai-infinite-scroll__product-price-{{ ai_gen_id }}">
              {{ product.price | money }}
            </div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <div class="ai-infinite-scroll__error-{{ ai_gen_id }}">
        No products found in this collection.
      </div>
    {% endif %}
  </div>

  <div class="ai-infinite-scroll__loading-{{ ai_gen_id }} ai-infinite-scroll__hidden-{{ ai_gen_id }}" data-loading>
    <div class="ai-infinite-scroll__spinner-{{ ai_gen_id }}"></div>
    <p>{{ block.settings.loading_text }}</p>
  </div>

  <div class="ai-infinite-scroll__end-message-{{ ai_gen_id }} ai-infinite-scroll__hidden-{{ ai_gen_id }}" data-end-message>
    {{ block.settings.end_message }}
  </div>

  <div class="ai-infinite-scroll__error-{{ ai_gen_id }} ai-infinite-scroll__hidden-{{ ai_gen_id }}" data-error>
    Failed to load more products. Please try again.
  </div>
</infinite-scroll-{{ ai_gen_id }}>

<script>
  (function() {
    class InfiniteScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentPage = 1;
        this.isLoading = false;
        this.hasMoreProducts = true;
        this.collectionHandle = this.dataset.collectionHandle;
        this.threshold = parseInt(this.dataset.threshold) || 300;
        this.productGrid = this.querySelector('[data-product-grid]');
        this.loadingIndicator = this.querySelector('[data-loading]');
        this.endMessage = this.querySelector('[data-end-message]');
        this.errorMessage = this.querySelector('[data-error]');
      }

      connectedCallback() {
        this.setupIntersectionObserver();
        this.checkInitialProducts();
      }

      checkInitialProducts() {
        const productCards = this.productGrid.querySelectorAll('.ai-infinite-scroll__product-card-{{ ai_gen_id }}');
        if (productCards.length === 0) {
          this.hasMoreProducts = false;
        }
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: `${this.threshold}px`,
          threshold: 0
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.isLoading && this.hasMoreProducts) {
              this.loadMoreProducts();
            }
          });
        }, options);

        this.observer.observe(this.productGrid);
      }

      async loadMoreProducts() {
        if (this.isLoading || !this.hasMoreProducts) return;

        this.isLoading = true;
        this.showLoading();
        this.hideError();

        try {
          this.currentPage++;
          const url = `/collections/${this.collectionHandle}?page=${this.currentPage}&view=ajax`;
          const response = await fetch(url);

          if (!response.ok) {
            throw new Error('Failed to fetch products');
          }

          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newProducts = doc.querySelectorAll('.ai-infinite-scroll__product-card-{{ ai_gen_id }}');

          if (newProducts.length === 0) {
            this.hasMoreProducts = false;
            this.hideLoading();
            this.showEndMessage();
            this.observer.disconnect();
          } else {
            newProducts.forEach((product) => {
              this.productGrid.appendChild(product.cloneNode(true));
            });
            this.hideLoading();
          }
        } catch (error) {
          console.error('Error loading products:', error);
          this.hideLoading();
          this.showError();
          this.currentPage--;
        } finally {
          this.isLoading = false;
        }
      }

      showLoading() {
        this.loadingIndicator.classList.remove('ai-infinite-scroll__hidden-{{ ai_gen_id }}');
      }

      hideLoading() {
        this.loadingIndicator.classList.add('ai-infinite-scroll__hidden-{{ ai_gen_id }}');
      }

      showEndMessage() {
        this.endMessage.classList.remove('ai-infinite-scroll__hidden-{{ ai_gen_id }}');
      }

      showError() {
        this.errorMessage.classList.remove('ai-infinite-scroll__hidden-{{ ai_gen_id }}');
      }

      hideError() {
        this.errorMessage.classList.add('ai-infinite-scroll__hidden-{{ ai_gen_id }}');
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('infinite-scroll-{{ ai_gen_id }}', InfiniteScroll{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Infinite scroll products",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Scroll behavior"
    },
    {
      "type": "range",
      "id": "scroll_threshold",
      "label": "Load distance",
      "min": 100,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 300,
      "info": "Distance from bottom before loading more products"
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#2c2d2e"
    },
    {
      "type": "range",
      "id": "price_font_size",
      "label": "Price size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#2c2d2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#1d58ba"
    },
    {
      "type": "header",
      "content": "Loading state"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading text",
      "default": "Loading more products..."
    },
    {
      "type": "color",
      "id": "loading_text_color",
      "label": "Text color",
      "default": "#2c2d2e"
    },
    {
      "type": "color",
      "id": "spinner_color",
      "label": "Spinner color",
      "default": "#1d58ba"
    },
    {
      "type": "header",
      "content": "End message"
    },
    {
      "type": "text",
      "id": "end_message",
      "label": "End message",
      "default": "You've reached the end of the collection"
    },
    {
      "type": "color",
      "id": "end_message_color",
      "label": "Text color",
      "default": "#2c2d2e"
    }
  ],
  "presets": [
    {
      "name": "Infinite scroll products"
    }
  ]
}
{% endschema %}
