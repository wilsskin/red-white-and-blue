{% assign section_landing = page.metafields.custom.section_landing.value %}

<div class="section-landing page-width">
  <div class="section-landing__header">
    <h1 class="section-landing__title">{{ section_landing.title }}</h1>
  </div>

  {% assign collections = section_landing.collections.value %}

  {% if collections.size > 0 %}
    <ul class="section-landing__grid list-unstyled" role="list">
      {% for collection in collections %}
        <li class="section-landing__item">
          <a href="{{ collection.url }}" class="section-landing__card card card--card">
            <div class="card__inner">
              <div class="card__media">
                {% if collection.featured_image %}
                  <div class="media media--transparent media--adapt">
                    <img
                      src="{{ collection.featured_image | image_url: width: 600 }}"
                      alt="{{ collection.featured_image.alt | escape }}"
                      width="600"
                      height="{{ 600 | divided_by: collection.featured_image.aspect_ratio | round }}"
                      loading="lazy"
                    >
                  </div>
                {% else %}
                  <div class="media media--transparent media--adapt section-landing__placeholder">
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {% endif %}
              </div>
            </div>
            <div class="card__content">
              <div class="card__information">
                <h2 class="card__heading h3">
                  {{ collection.title }}
                </h2>
              </div>
            </div>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No collections found.</p>
  {% endif %}
</div>

<style>
  .section-landing {
    padding-top: 3.6rem;
    padding-bottom: 3.6rem;
  }

  .section-landing__header {
    margin-bottom: 3rem;
  }

  .section-landing__title {
    margin: 0;
  }

  .section-landing__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
  }

  .section-landing__card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .section-landing__card:hover .card__media img {
    transform: scale(1.03);
    transition: transform 0.4s ease;
  }

  .section-landing__card .card__media img {
    transition: transform 0.4s ease;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-landing__placeholder {
    background: #f4f4f4;
    min-height: 200px;
  }

  @media screen and (min-width: 750px) {
    .section-landing__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .section-landing__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
